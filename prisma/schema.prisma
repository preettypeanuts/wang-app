generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["monmon_whethertie"]
}

// ——— Better Auth (sync with lib/auth/auth.ts) ———

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  /// Wallet used when the user does not mention one in chat.
  defaultWalletId String?
  defaultWallet   Wallet? @relation("UserDefaultWallet", fields: [defaultWalletId], references: [id], onDelete: SetNull)

  transactions    Transaction[]
  inboxMessages   InboxMessage[]
  categoryBudgets CategoryBudget[]
  plannedItems    PlannedItem[]
  plans           Plan[]
  savingsGoals    SavingsGoal[]
  pushSubscriptions PushSubscription[]
  appNotifications  AppNotification[]
  aiInsightCaches                AiInsightCache[]
  categoryOverrides              UserCategoryOverride[]
  userCategories                 UserCategory[]
  recurringSuggestionDismissals  RecurringSuggestionDismissal[]
  wallets                        Wallet[]

  @@unique([email])
  @@map("user")
  @@schema("monmon_whethertie")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
  @@schema("monmon_whethertie")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
  @@schema("monmon_whethertie")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
  @@schema("monmon_whethertie")
}

// ——— App data ———

enum TransactionType {
  income
  expense
  transfer
  adjustment

  @@schema("monmon_whethertie")
}

enum WalletType {
  cash
  bank
  ewallet
  other

  @@schema("monmon_whethertie")
}

enum InboxMessageRole {
  user
  assistant

  @@schema("monmon_whethertie")
}

enum InboxMessageKind {
  chat
  daily_summary
  weekly_summary

  @@schema("monmon_whethertie")
}

model Wallet {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  type           WalletType
  icon           String?
  colorHex       String?
  initialBalance Int          @default(0)
  isDefault      Boolean      @default(false)
  isArchived     Boolean      @default(false)
  adminFeeAmount Int?
  adminFeeDay    Int?
  createdAt      DateTime     @default(now())
  transactions   Transaction[]
  defaultForUsers User[]      @relation("UserDefaultWallet")
  adminFeePlan   PlannedItem? @relation("WalletAdminFeePlan")

  @@index([userId])
  @@schema("monmon_whethertie")
}

model Transaction {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           TransactionType
  amount         Int
  category       String
  description    String
  occurredAt     DateTime
  rawInput       String
  createdAt      DateTime        @default(now())
  inboxMessageId String?
  inboxMessage   InboxMessage?   @relation(fields: [inboxMessageId], references: [id], onDelete: SetNull)
  walletId       String?
  wallet         Wallet?         @relation(fields: [walletId], references: [id], onDelete: SetNull)
  /// Links the two signed legs of a wallet-to-wallet transfer.
  transferPairId String?

  @@index([userId, occurredAt])
  @@index([userId, type])
  @@index([userId, type, occurredAt])
  @@index([inboxMessageId])
  @@index([walletId])
  @@index([transferPairId])
  @@schema("monmon_whethertie")
}

enum PlannedRepeatInterval {
  monthly
  weekly
  yearly

  @@schema("monmon_whethertie")
}

enum PlannedItemKind {
  bill
  subscription
  installment
  income

  @@schema("monmon_whethertie")
}

enum BudgetLimitMode {
  daily
  fixed

  @@schema("monmon_whethertie")
}

model CategoryBudget {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category        String
  periodMonth     String
  limitMode       BudgetLimitMode @default(daily)
  dailyAmount     Int?
  fixedLimit      Int?
  dayCount        Int?
  note            String?
  repeatNextMonth Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([userId, category, periodMonth])
  @@index([userId, periodMonth])
  @@schema("monmon_whethertie")
}

model PlannedItem {
  id                   String                @id @default(cuid())
  userId               String
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                 String
  kind                 PlannedItemKind
  repeat               PlannedRepeatInterval @default(monthly)
  amount               Int
  flowType             TransactionType       @default(expense)
  category             String                @default("other")
  startAt              DateTime
  endAt                DateTime?
  installmentCount     Int?
  paidInstallmentCount Int                   @default(0)
  note                 String?
  repeatNextMonth      Boolean               @default(false)
  walletId             String?               @unique
  wallet               Wallet?               @relation("WalletAdminFeePlan", fields: [walletId], references: [id], onDelete: Cascade)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([userId])
  @@schema("monmon_whethertie")
}

enum PlanStatus {
  active
  done

  @@schema("monmon_whethertie")
}

model Plan {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  amount    Int
  category  String     @default("shopping")
  status    PlanStatus @default(active)
  note      String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([userId, status])
  @@schema("monmon_whethertie")
}

enum SavingsGoalStatus {
  active
  completed
  paused

  @@schema("monmon_whethertie")
}

model SavingsGoal {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  targetAmount Int
  savedAmount  Int               @default(0)
  status       SavingsGoalStatus @default(active)
  note         String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([userId, status])
  @@schema("monmon_whethertie")
}

model InboxMessage {
  id                  String           @id @default(cuid())
  userId              String
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role                InboxMessageRole
  kind                InboxMessageKind @default(chat)
  content             String
  insight             String?
  /// Fingerprint of transaction count + totals when insight was generated.
  insightSignature    String?
  createdAt           DateTime         @default(now())
  summaryDate         DateTime?
  transactions        Transaction[]
  /// Snapshot when the linked transaction is removed from Journal.
  orphanedTransaction Json?

  @@unique([userId, summaryDate, kind])
  @@index([userId, createdAt])
  @@index([userId, kind])
  @@schema("monmon_whethertie")
}

enum AppNotificationKind {
  bill_reminder
  daily_summary
  weekly_summary
  ai_brief
  alert
  savings

  @@schema("monmon_whethertie")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@schema("monmon_whethertie")
}

model AppNotification {
  id        String              @id @default(cuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      AppNotificationKind
  title     String
  body      String
  href      String              @default("/overview")
  dedupeKey String
  readAt    DateTime?
  pushedAt  DateTime?
  createdAt DateTime            @default(now())

  @@unique([userId, dedupeKey])
  @@index([userId, readAt, createdAt])
  @@schema("monmon_whethertie")
}

enum AiInsightCacheType {
  journal_condition
  plans_insight

  @@schema("monmon_whethertie")
}

model AiInsightCache {
  id        String             @id @default(cuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      AiInsightCacheType
  dateKey   String
  payload   Json
  createdAt DateTime           @default(now())

  @@unique([userId, type, dateKey])
  @@index([userId])
  @@map("ai_insight_cache")
  @@schema("monmon_whethertie")
}

model UserCategoryOverride {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  keyword   String
  type      TransactionType
  category  String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([userId, keyword, type])
  @@index([userId])
  @@schema("monmon_whethertie")
}

model UserCategory {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug           String
  label          String
  icon           String
  iconIsCustom   Boolean         @default(false)
  accentLight    String?
  accentDark     String?
  colorIsCustom  Boolean         @default(false)
  type           TransactionType
  baseCategoryId String?
  hidden         Boolean         @default(false)
  sortOrder      Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([userId, slug])
  @@index([userId])
  @@map("user_category")
  @@schema("monmon_whethertie")
}

model RecurringSuggestionDismissal {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  keyword   String
  createdAt DateTime @default(now())

  @@unique([userId, keyword])
  @@schema("monmon_whethertie")
}
